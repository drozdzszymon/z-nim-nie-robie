{
  "expo": {
    "name": "Z NIM NIE ROBIĘ",
    "slug": "z-nim-nie-robie",
    "owner": "simon_on",
    "version": "2.0.2",
    "icon": "./assets/images/icon.png",
    "orientation": "default",
    "scheme": "znimnierobie",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "description": "Oficjalna aplikacja treningowa do zarządzania parami, rundami i rotacją zawodników podczas treningów BJJ, grapplingu i zadaniówek.",
    "platforms": [
      "android",
      "ios",
      "web"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": false
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-router",
      "./plugins/with-adi-registration",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#07111F",
          "image": "./assets/images/icon.png",
          "imageWidth": 260
        }
      ]
    ],
    "android": {
      "package": "pl.znimnierobie.app",
      "versionCode": 3,
      "edgeToEdgeEnabled": true,
      "permissions": [],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#07111F",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "ios": {
      "bundleIdentifier": "pl.znimnierobie.app",
      "buildNumber": "1",
      "supportsTablet": true
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "922b6996-f702-43bf-98a4-a3a4d9d25aa7"
      }
    }
  }
}
